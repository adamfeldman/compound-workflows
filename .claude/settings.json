{
  "permissions": {
    "allow": [
      "Write(//.workflows/**)",
      "Edit(//.workflows/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/auto-approve.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/plugin-qa-check.sh"
          }
        ]
      }
    ]
  }
}
